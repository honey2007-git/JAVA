SalesExecutive.Java 
import java.util.Scanner; 
class SalesExecutive { 
private int empNo; 
private String empName; 
private double q1, q2, q3, q4, totalSales, averageSales; 
SalesExecutive(int no, String name, double q1, double q2, double 
q3, double q4) { 
this.empNo = no; 
this.empName = name; 
this.q1 = q1; 
this.q2 = q2; 
this.q3 = q3; 
this.q4 = q4; 
} 
public void calculateSales() { 
totalSales = q1 + q2 + q3 + q4; 
averageSales = totalSales / 4; 
} 
public void displayReport() { 
System.out.println(“\nSales Report”); 
System.out.println(“Emp No: “ + empNo); 
System.out.println(“Name: “ + empName); 
System.out.println(“Total Sales: “ + totalSales); 
System.out.println(“Average Sales: “ + averageSales); 
} 
} 

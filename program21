import java.util.Scanner; 
// User defined exception 
class LessBalanceException extends Exception { 
LessBalanceException() { 
super("Withdraw amount (Rs) is not valid. Minimum balance should be Rs.500"); 
} 
} 
// Account class 
class Account { 
double balance = 500; // minimum balance 
void deposit(double amount) { 
balance = balance + amount; 
System.out.println("Amount Deposited: " + amount); 
System.out.println("Current Balance: " + balance); 
} 
void withdraw(double amount) throws LessBalanceException { 
if (balance - amount < 500) { 
throw new LessBalanceException(); 
} 
balance = balance - amount; 
System.out.println("Amount Withdrawn: " + amount); 
System.out.println("Current Balance: " + balance); 
} 
} 
public class BankDemo {
public static void main(String[] args) { 
Scanner sc = new Scanner(System.in); 
Account acc = new Account(); 
try { 
System.out.print("Enter amount to deposit: "); 
double d = sc.nextDouble(); 
acc.deposit(d); 
System.out.print("Enter amount to withdraw: "); 
double w = sc.nextDouble(); 
acc.withdraw(w); 
} catch (LessBalanceException e) { 
System.out.println(e.getMessage()); 
} 
} 
} 

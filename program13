Calculator.java 
import java.util.Scanner; 
class Calculator {  
// Method 1: add two integers 
int add(int a, int b) { 
return a + b; 
} 
// Method 2: add three integers 
int add(int a, int b, int c) { 
return a + b + c; 
} 
// Method 3: add two double values 
double add(double a, double b) { 
return a + b; 
} 
} 
MethodOverloadingDemo.Java 
public class MethodOverloadingDemo { 
public static void main(String[] args) { 
Scanner sc = new Scanner(System.in); 
Calculator calc = new Calculator(); 
System.out.print(“Enter two integers: “); 
int a = sc.nextInt(); 
int b = sc.nextInt(); 
System.out.print(“Enter three integers: “); 
int x = sc.nextInt(); 
int y = sc.nextInt(); 
int z = sc.nextInt(); 
System.out.print(“Enter two decimal numbers: “); 
double d1 = sc.nextDouble(); 
double d2 = sc.nextDouble(); 
System.out.println(“\nResults:”); 
System.out.println(“Sum of two integers = “ + calc.add(a, b)); 
System.out.println(“Sum of three integers = “ + calc.add(x, y, z));
System.out.println(“Sum of two decimals = “ + calc.add(d1,d2));
}
}

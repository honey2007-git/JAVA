public class EmployeeSalaryDemo { 
public static void main(String[] args) { 
Scanner sc = new Scanner(System.in); 
System.out.print(“Enter Employee No: “); 
int no = sc.nextInt(); 
sc.nextLine(); 
System.out.print(“Enter Name: “); 
String name = sc.nextLine(); 
System.out.print(“Enter Age: “); 
int age = sc.nextInt(); 
System.out.print(“Enter Basic Salary: “); 
double basic = sc.nextDouble(); 
System.out.print(“Enter DA: “); 
double DA = sc.nextDouble(); 
System.out.print(“Enter HRA: “); 
double HRA = sc.nextDouble(); 
System.out.print(“Enter CA: “); 
double CA = sc.nextDouble(); 
System.out.print(“Enter PT: “); 
double PT = sc.nextDouble(); 
System.out.print(“Enter IT: “); 
double IT = sc.nextDouble();
Employee emp = new Employee(no, name, age, basic, DA, HRA, CA, PT, IT); 
emp.calculateSalary(); 
emp.display();
}
}

Employee.Java 
import java.util.Scanner; 
class Employee { 
private int empNo, age; 
private String empName; 
private double basic, DA, HRA, CA, PT, IT, grossSalary; 
// Constructor 
Employee(int no, String name, int age, double basic, 
double DA, double HRA, double CA, double PT, double IT) { 
this.empNo = no; 
this.empName = name; 
this.age = age; 
this.basic = basic; 
this.DA = DA; 
this.HRA = HRA; 
this.CA = CA; 
this.PT = PT; 
this.IT = IT; 
} 
// Method to calculate salary 
public void calculateSalary() { 
grossSalary = basic + DA + HRA + CA – PT – IT; 
} 
// Display method 
public void display() { 
System.out.println(“\nEmployee Details”); 
System.out.println(“Emp No: “ + empNo); 
System.out.println(“Name: “ + empName); 
System.out.println(“Age: “ + age); 
System.out.println(“Gross Salary: “ + grossSalary); 
} 
} 

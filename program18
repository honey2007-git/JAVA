class Outer { 
private String message = "Hello from Outer Class"; 
// Inner class 
class Inner { 
void display() { 
// accessing private member of outer class 
System.out.println(message); 
System.out.println("Accessing Outer class member from 
Inner class"); 
} 
} 
} 
public class InnerClassDemo { 
public static void main(String[] args) { 
Outer obj = new Outer(); 
Outer.Inner innerObj = obj.new Inner(); 
innerObj.display();
}
}
